<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PasswordGenerator.MainPage"
             BackgroundColor="{StaticResource Bg}">

    <ScrollView>
        <VerticalStackLayout Padding="22,50,22,40" Spacing="18">

            <!-- Заголовок -->
            <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                <Label Text="Randoming Pass"
                       FontSize="32"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       TextColor="{StaticResource TextPrimary}"/>
                <Label Text="ГЕНЕРАТОР ПАРОЛЕЙ"
                       FontSize="11"
                       HorizontalOptions="Center"
                       TextColor="{StaticResource TextSecondary}"
                       CharacterSpacing="8"/>
            </VerticalStackLayout>

            <!-- Карточка с паролем -->
            <Border Stroke="{StaticResource Border}"
                    StrokeThickness="1"
                    BackgroundColor="{StaticResource Surface}"
                    Padding="22,24"
                    Margin="0,24,0,0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="14"/>
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="18">
                    <Label x:Name="PasswordLabel"
                           Text="нажмите СГЕНЕРИРОВАТЬ"
                           FontSize="20"
                           FontFamily="Courier New"
                           TextColor="{StaticResource TextSecondary}"
                           HorizontalTextAlignment="Center"
                           LineBreakMode="CharacterWrap"
                           MinimumHeightRequest="60"/>

                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="10">
                        <Button x:Name="CopyButton"
                                Text="КОПИРОВАТЬ"
                                Clicked="OnCopyClicked"
                                BackgroundColor="{StaticResource SurfaceAlt}"
                                TextColor="{StaticResource TextPrimary}"
                                FontSize="12"
                                FontAttributes="Bold"
                                CharacterSpacing="2"
                                Padding="20,10"
                                CornerRadius="20"/>
                        <Button x:Name="ReplaceButton"
                                Text="ЗАМЕНИТЬ"
                                Clicked="OnGenerateClicked"
                                BackgroundColor="{StaticResource SurfaceAlt}"
                                TextColor="{StaticResource TextPrimary}"
                                FontSize="12"
                                FontAttributes="Bold"
                                CharacterSpacing="2"
                                Padding="20,10"
                                CornerRadius="20"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Индикатор надёжности (одна полоса) -->
            <VerticalStackLayout Spacing="8" Margin="4,8,4,0">
                <Grid ColumnDefinitions="*,Auto">
                    <Label Grid.Column="0"
                           Text="НАДЁЖНОСТЬ"
                           TextColor="{StaticResource TextSecondary}"
                           FontSize="11"
                           CharacterSpacing="3"/>
                    <Label x:Name="StrengthLabel"
                           Grid.Column="1"
                           Text="—"
                           TextColor="{StaticResource TextSecondary}"
                           FontSize="11"
                           FontAttributes="Bold"
                           CharacterSpacing="2"/>
                </Grid>

                <ProgressBar x:Name="StrengthBar"
                             Progress="0"
                             ProgressColor="{StaticResource TextSecondary}"
                             HeightRequest="6"/>
            </VerticalStackLayout>

            <!-- Длина пароля -->
            <VerticalStackLayout Spacing="6" Margin="4,14,4,0">
                <Grid ColumnDefinitions="*,Auto">
                    <Label Grid.Column="0"
                           Text="ДЛИНА"
                           TextColor="{StaticResource TextSecondary}"
                           FontSize="11"
                           CharacterSpacing="3"/>
                    <Label x:Name="LengthLabel"
                           Grid.Column="1"
                           Text="16"
                           TextColor="{StaticResource Accent}"
                           FontSize="14"
                           FontAttributes="Bold"/>
                </Grid>
                <Slider x:Name="LengthSlider"
                        Minimum="4"
                        Maximum="64"
                        Value="16"
                        ValueChanged="OnLengthChanged"
                        MinimumTrackColor="{StaticResource Accent}"
                        MaximumTrackColor="{StaticResource SurfaceAlt}"/>
            </VerticalStackLayout>

            <!-- Типы символов -->
            <Label Text="СИМВОЛЫ"
                   TextColor="{StaticResource TextSecondary}"
                   FontSize="11"
                   CharacterSpacing="3"
                   Margin="4,14,0,0"/>

            <Border BackgroundColor="{StaticResource Surface}"
                    StrokeThickness="0"
                    Padding="18,4">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="0">

                    <Grid ColumnDefinitions="Auto,*" Padding="0,10">
                        <CheckBox x:Name="UpperCheck" Grid.Column="0" IsChecked="True" Color="{StaticResource Accent}"/>
                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center" Margin="8,0,0,0">
                            <Label Text="A-Z" TextColor="#569CD6" FontFamily="Courier New" FontSize="15"/>
                            <Label Text="заглавные" TextColor="{StaticResource TextSecondary}" FontSize="11"/>
                        </VerticalStackLayout>
                    </Grid>

                    <BoxView HeightRequest="1" BackgroundColor="{StaticResource SurfaceAlt}"/>

                    <Grid ColumnDefinitions="Auto,*" Padding="0,10">
                        <CheckBox x:Name="LowerCheck" Grid.Column="0" IsChecked="True" Color="{StaticResource Accent}"/>
                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center" Margin="8,0,0,0">
                            <Label Text="a-z" TextColor="{StaticResource TextPrimary}" FontFamily="Courier New" FontSize="15"/>
                            <Label Text="строчные" TextColor="{StaticResource TextSecondary}" FontSize="11"/>
                        </VerticalStackLayout>
                    </Grid>

                    <BoxView HeightRequest="1" BackgroundColor="{StaticResource SurfaceAlt}"/>

                    <Grid ColumnDefinitions="Auto,*" Padding="0,10">
                        <CheckBox x:Name="DigitCheck" Grid.Column="0" IsChecked="True" Color="{StaticResource Accent}"/>
                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center" Margin="8,0,0,0">
                            <Label Text="0-9" TextColor="#B5CEA8" FontFamily="Courier New" FontSize="15"/>
                            <Label Text="цифры" TextColor="{StaticResource TextSecondary}" FontSize="11"/>
                        </VerticalStackLayout>
                    </Grid>

                    <BoxView HeightRequest="1" BackgroundColor="{StaticResource SurfaceAlt}"/>

                    <Grid ColumnDefinitions="Auto,*" Padding="0,10">
                        <CheckBox x:Name="SymbolCheck" Grid.Column="0" IsChecked="True" Color="{StaticResource Accent}"/>
                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center" Margin="8,0,0,0">
                            <Label Text="!@#$%" TextColor="#CE9178" FontFamily="Courier New" FontSize="15"/>
                            <Label Text="спецсимволы" TextColor="{StaticResource TextSecondary}" FontSize="11"/>
                        </VerticalStackLayout>
                    </Grid>

                    <BoxView HeightRequest="1" BackgroundColor="{StaticResource SurfaceAlt}"/>

                    <Grid ColumnDefinitions="Auto,*" Padding="0,10">
                        <CheckBox x:Name="AmbiguousCheck" Grid.Column="0" IsChecked="False" Color="{StaticResource Accent}"/>
                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center" Margin="8,0,0,0">
                            <Label Text="без I l 1 O 0" TextColor="{StaticResource TextPrimary}" FontFamily="Courier New" FontSize="15"/>
                            <Label Text="исключить похожие" TextColor="{StaticResource TextSecondary}" FontSize="11"/>
                        </VerticalStackLayout>
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <!-- Кнопка генерации -->
            <Button x:Name="GenerateButton"
                    Text="СГЕНЕРИРОВАТЬ"
                    Clicked="OnGenerateClicked"
                    BackgroundColor="{StaticResource Accent}"
                    TextColor="White"
                    FontSize="15"
                    FontAttributes="Bold"
                    CharacterSpacing="4"
                    HeightRequest="54"
                    CornerRadius="27"
                    Margin="0,22,0,0"/>

            <!-- История -->
            <VerticalStackLayout x:Name="HistorySection" Spacing="8" Margin="0,24,0,0" IsVisible="False">
                <Grid ColumnDefinitions="*,Auto" Margin="4,0">
                    <Label Grid.Column="0"
                           Text="ИСТОРИЯ"
                           TextColor="{StaticResource TextSecondary}"
                           FontSize="11"
                           CharacterSpacing="3"/>
                    <Label Grid.Column="1"
                           Text="ОЧИСТИТЬ"
                           TextColor="{StaticResource Accent}"
                           FontSize="11"
                           FontAttributes="Bold"
                           CharacterSpacing="2">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnClearHistory"/>
                        </Label.GestureRecognizers>
                    </Label>
                </Grid>

                <CollectionView x:Name="HistoryList" SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border BackgroundColor="{StaticResource Surface}"
                                    StrokeThickness="0"
                                    Padding="14,11"
                                    Margin="0,4">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10"/>
                                </Border.StrokeShape>
                                <Label Text="{Binding .}"
                                       FontFamily="Courier New"
                                       TextColor="{StaticResource TextSecondary}"
                                       FontSize="13"
                                       LineBreakMode="MiddleTruncation"/>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

            <Label Text="ТЭПК · группа 1942с"
                   TextColor="{StaticResource TextSecondary}"
                   FontSize="10"
                   HorizontalOptions="Center"
                   Margin="0,30,0,0"
                   CharacterSpacing="2"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
