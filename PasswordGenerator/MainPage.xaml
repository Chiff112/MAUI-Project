<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PasswordGenerator.MainPage"
             BackgroundColor="#121212"
             Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Padding="22,50,22,40" Spacing="18">

            <!-- Заголовок -->
            <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                <Label Text="Randoming Pass"
                       FontSize="32"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       TextColor="#FFFFFF"/>
                <Label Text="ГЕНЕРАТОР ПАРОЛЕЙ"
                       FontSize="11"
                       HorizontalOptions="Center"
                       TextColor="#9E9E9E"
                       CharacterSpacing="8"/>
            </VerticalStackLayout>

            <!-- Карточка с паролем -->
            <Border Stroke="#3E3E42"
                    StrokeThickness="1"
                    BackgroundColor="#1E1E1E"
                    Padding="22,24"
                    Margin="0,24,0,0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="14"/>
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="18">
                    <Label x:Name="PasswordLabel"
                           Text="Нажмите Сгенерировать"
                           FontSize="20"
                           FontFamily="Courier New"
                           TextColor="#FFFFFF"
                           HorizontalTextAlignment="Center"
                           LineBreakMode="CharacterWrap"
                           MinimumHeightRequest="60"/>

                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="10">
                        <Button x:Name="CopyButton"
                                Text="Копировать"
                                Clicked="OnCopyClicked"
                                BackgroundColor="#2C2C2C"
                                TextColor="#FFFFFF"
                                FontSize="13"
                                Padding="20,10"
                                CornerRadius="20"/>
                        <Button Text="Заменить"
                                Clicked="OnGenerateClicked"
                                BackgroundColor="#2C2C2C"
                                TextColor="#FFFFFF"
                                FontSize="13"
                                Padding="20,10"
                                CornerRadius="20"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Индикатор надёжности -->
            <VerticalStackLayout Spacing="8" Margin="4,8,4,0">
                <Grid ColumnDefinitions="*,Auto">
                    <Label Grid.Column="0" Text="Надёжность" TextColor="#9E9E9E" FontSize="13"/>
                    <Label x:Name="StrengthLabel" Grid.Column="1" Text="—" TextColor="#9E9E9E" FontSize="13"/>
                </Grid>
                <ProgressBar x:Name="StrengthBar" Progress="0" ProgressColor="#696969" HeightRequest="6"/>
            </VerticalStackLayout>

            <!-- Длина пароля -->
            <VerticalStackLayout Spacing="6" Margin="4,14,4,0">
                <Grid ColumnDefinitions="*,Auto">
                    <Label Grid.Column="0" Text="Длина" TextColor="#9E9E9E" FontSize="18"/>
                    <Label x:Name="LengthLabel" Grid.Column="1" Text="16" TextColor="#696969" FontSize="18" FontAttributes="Bold"/>
                </Grid>
                <Slider x:Name="LengthSlider"
                        Minimum="4"
                        Maximum="64"
                        Value="16"
                        ValueChanged="OnLengthChanged"
                        MinimumTrackColor="#696969"
                        MaximumTrackColor="#2C2C2C"/>
            </VerticalStackLayout>

            <!-- Типы символов -->
            <Label Text="Символы" TextColor="#9E9E9E" FontSize="13" Margin="4,14,0,0"/>

            <Border BackgroundColor="#1E1E1E" StrokeThickness="0" Padding="18,4">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="0">

                    <Grid ColumnDefinitions="Auto,*" Padding="0,10">
                        <CheckBox x:Name="UpperCheck" Grid.Column="0" IsChecked="True" Color="#696969"/>
                        <Label Grid.Column="1" Text="Заглавные (A-Z)" TextColor="#FFFFFF" FontSize="15" VerticalOptions="Center" Margin="8,0,0,0"/>
                    </Grid>
                    <BoxView HeightRequest="1" BackgroundColor="#2C2C2C"/>

                    <Grid ColumnDefinitions="Auto,*" Padding="0,10">
                        <CheckBox x:Name="LowerCheck" Grid.Column="0" IsChecked="True" Color="#696969"/>
                        <Label Grid.Column="1" Text="Строчные (a-z)" TextColor="#FFFFFF" FontSize="15" VerticalOptions="Center" Margin="8,0,0,0"/>
                    </Grid>
                    <BoxView HeightRequest="1" BackgroundColor="#2C2C2C"/>

                    <Grid ColumnDefinitions="Auto,*" Padding="0,10">
                        <CheckBox x:Name="DigitCheck" Grid.Column="0" IsChecked="True" Color="#696969"/>
                        <Label Grid.Column="1" Text="Цифры (0-9)" TextColor="#FFFFFF" FontSize="15" VerticalOptions="Center" Margin="8,0,0,0"/>
                    </Grid>
                    <BoxView HeightRequest="1" BackgroundColor="#2C2C2C"/>

                    <Grid ColumnDefinitions="Auto,*" Padding="0,10">
                        <CheckBox x:Name="SymbolCheck" Grid.Column="0" IsChecked="True" Color="#696969"/>
                        <Label Grid.Column="1" Text="Спецсимволы (!@#$%)" TextColor="#FFFFFF" FontSize="15" VerticalOptions="Center" Margin="8,0,0,0"/>
                    </Grid>
                    <BoxView HeightRequest="1" BackgroundColor="#2C2C2C"/>

                    <Grid ColumnDefinitions="Auto,*" Padding="0,10">
                        <CheckBox x:Name="AmbiguousCheck" Grid.Column="0" IsChecked="False" Color="#696969"/>
                        <Label Grid.Column="1" Text="Исключить похожие (I l 1 O 0)" TextColor="#FFFFFF" FontSize="15" VerticalOptions="Center" Margin="8,0,0,0"/>
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <!-- Кнопка генерации -->
            <Button Text="Сгенерировать"
                    Clicked="OnGenerateClicked"
                    BackgroundColor="#696969"
                    TextColor="#FFFFFF"
                    FontSize="15"
                    FontAttributes="Bold"
                    HeightRequest="54"
                    CornerRadius="27"
                    Margin="0,22,0,0"/>

            <!-- История -->
            <VerticalStackLayout x:Name="HistorySection" Spacing="8" Margin="0,24,0,0" IsVisible="False">
                <Grid ColumnDefinitions="*,Auto" Margin="4,0">
                    <Label Grid.Column="0" Text="История" TextColor="#9E9E9E" FontSize="13"/>
                    <Label Grid.Column="1" Text="Очистить" TextColor="#696969" FontSize="13">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnClearHistory"/>
                        </Label.GestureRecognizers>
                    </Label>
                </Grid>

                <CollectionView x:Name="HistoryList" SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border BackgroundColor="#1E1E1E" StrokeThickness="0" Padding="14,11" Margin="0,4">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10"/>
                                </Border.StrokeShape>
                                <Label Text="{Binding .}" FontFamily="Courier New" TextColor="#9E9E9E" FontSize="13" LineBreakMode="MiddleTruncation"/>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

            <Label Text="Привет это - группа 1942с"
                   TextColor="#9E9E9E"
                   FontSize="10"
                   HorizontalOptions="Center"
                   Margin="0,30,0,0"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>